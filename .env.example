# Deploy configuration (docker compose reads these). Copy to `.env` to override.

# Host port the frontend (nginx) is published on → http://localhost:UDA_PORT
UDA_PORT=8094

# Prototype identifier (compose project scoping)
PROTOTYPE_ID=lounge

# --- Backend (defaults are fine for the containerized deploy) ---
# Port the Node backend listens on INSIDE its container
# PORT=8080
# Where the backend persists its JSON state (a Docker volume in deploy)
# DATA_FILE=/data/app.json
